{
  "App": {
    "SelfUrl": "https://localhost:44305",
    "AngularUrl": "http://localhost:4200",
    "CorsOrigins": "https://*.KnowledgeHub.com,http://localhost:4200,",
    "RedirectAllowedUrls": "http://localhost:4200,",
    "DisablePII": false,
    "HealthCheckUrl": "/health-status"
  },
  "Meilisearch": {
    "Host": "http://localhost:7700",
    "ApiKey": "",
    "IndexName": "documents",
    "EmbeddingDimension": 768
  },
  "EmbeddingService": {
    "BaseUrl": "",
    "ApiKey": ""
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "Enrich": ["FromLogContext"],
    "WriteTo": [
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "File",
              "Args": {
                "path": "Logs/logs.txt"
              }
            }
          ]
        }
      },
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "Console"
            }
          ]
        }
      }
    ]
  },
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5433;Database=KnowledgeHub;User ID=postgres;Password=postgres;"
  },
  "AuthServer": {
    "Authority": "https://localhost:44305",
    "RequireHttpsMetadata": true,
    "SwaggerClientId": "KnowledgeHub_Swagger",
    "CertificatePassPhrase": "YOUR_CERTIFICATE_PASSPHRASE_HERE"
  },
  "StringEncryption": {
    "DefaultPassPhrase": "YOUR_DEFAULT_PASSPHRASE_HERE"
  }}