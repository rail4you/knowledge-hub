# ============================================================
# .env.production - KnowledgeHub 生产环境配置
# ============================================================
# 基于项目 appsettings.json 和 dynamic-env.json 填写

# ============================================================
# 应用程序 URL（必须修改为实际域名）
# ============================================================
APP_SELF_URL=https://119.45.170.4:44354
APP_ANGULAR_URL=http://119.45.170.4
APP_CORS_ORIGINS=http://119.45.170.4
APP_REDIRECT_URLS=http://119.45.170.4

# ============================================================
# 数据库
# ============================================================
POSTGRES_PASSWORD=postgres

# ============================================================
# HTTPS 证书密码
# ============================================================
CERT_PASSWORD=91f91912-5ab0-49df-8166-23377efaf3cc

# ============================================================
# Meilisearch 全文搜索引擎
# ============================================================
MEILISEARCH_MASTER_KEY=aSampleMasterKey

# ============================================================
# Embedding API（用于语义搜索）
# ============================================================
EMBEDDING_API_KEY=YOUR_QWEN_API_KEY_HERE

# ============================================================
# Qwen API（阿里通义千问）- 用于 AI 功能
# ============================================================
QWEN_API_KEY=YOUR_QWEN_API_KEY_HERE
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# ============================================================
# JWT 证书密码
# ============================================================
JWT_CERTIFICATE_PASSWORD=YOUR_CERTIFICATE_PASSPHRASE_HERE

# ============================================================
# 字符串加密密钥
# ============================================================
STRING_ENCRYPTION_PASSPHRASE=YOUR_DEFAULT_PASSPHRASE_HERE
