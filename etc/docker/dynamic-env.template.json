{
  "production": true,
  "application": {
    "baseUrl": "${PUBLIC_URL}/admin",
    "name": "易课通知识库系统"
  },
  "oAuthConfig": {
    "issuer": "${PUBLIC_URL}/",
    "redirectUri": "${PUBLIC_URL}/admin",
    "postLogoutRedirectUri": "${PUBLIC_URL}",
    "clientId": "KnowledgeHub_App",
    "responseType": "code",
    "scope": "offline_access openid profile email phone KnowledgeHub",
    "requireHttps": false
  },
  "apis": {
    "default": {
      "url": "${PUBLIC_URL}",
      "rootNamespace": "KnowledgeHub"
    },
    "AbpAccountPublic": {
      "url": "${PUBLIC_URL}",
      "rootNamespace": "AbpAccountPublic"
    }
  }
}
