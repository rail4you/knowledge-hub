{
  "production": true,
  "application": {
    "baseUrl": "${APP_ANGULAR_URL}",
    "name": "KnowledgeHub"
  },
  "oAuthConfig": {
    "issuer": "${APP_SELF_URL}/",
    "redirectUri": "${APP_ANGULAR_URL}",
    "clientId": "KnowledgeHub_App",
    "responseType": "code",
    "scope": "offline_access openid profile email phone KnowledgeHub"
  },
  "apis": {
    "default": {
      "url": "${APP_SELF_URL}",
      "rootNamespace": "KnowledgeHub"
    },
    "AbpAccountPublic": {
      "url": "${APP_SELF_URL}",
      "rootNamespace": "AbpAccountPublic"
    }
  }
}
