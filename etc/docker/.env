# ============================================================
# .env - KnowledgeHub 本地开发环境配置
# ============================================================
# 此文件用于本地 docker-compose up
# 生产环境请使用 .env.production
# ============================================================

APP_SELF_URL=https://localhost:44354
APP_ANGULAR_URL=http://localhost:4200
APP_CORS_ORIGINS=http://localhost:4200
APP_REDIRECT_URLS=http://localhost:4200

POSTGRES_PASSWORD=postgres
MEILISEARCH_MASTER_KEY=aSampleMasterKey
EMBEDDING_API_KEY=YOUR_QWEN_API_KEY_HERE
QWEN_API_KEY=YOUR_QWEN_API_KEY_HERE
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
JWT_CERTIFICATE_PASSWORD=YOUR_CERTIFICATE_PASSPHRASE_HERE
STRING_ENCRYPTION_PASSPHRASE=YOUR_DEFAULT_PASSPHRASE_HERE

REGISTRY=mycompany
IMAGE_TAG=latest
