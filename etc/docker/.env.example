# ============================================================
# .env.example - KnowledgeHub 生产环境配置模板
# ============================================================
# 复制此文件为 .env.production 并修改相应值
# 
# 使用方式:
#   cp .env.example .env.production
#   # 编辑 .env.production
#   ./deploy-production.sh --deploy
# ============================================================

# ----------------------------------------------------------
# 服务器配置
# ----------------------------------------------------------
SERVER_HOST=119.45.170.4
SERVER_PORT=22
SERVER_USER=ubuntu
SERVER_PASSWORD=your_password_here

# ----------------------------------------------------------
# 应用 URL 配置（重要！）
# ----------------------------------------------------------
# API 服务地址（浏览器访问）
APP_SELF_URL=http://119.45.170.4:44354
# Angular 前端地址
APP_ANGULAR_URL=http://119.45.170.4
# CORS 允许的来源（逗号分隔）
APP_CORS_ORIGINS=http://localhost:4200,http://119.45.170.4
# OpenIddict 回调 URL（逗号分隔）
APP_REDIRECT_URLS=http://localhost:4200,http://119.45.170.4

# ----------------------------------------------------------
# 数据库配置
# ----------------------------------------------------------
POSTGRES_PASSWORD=your_secure_password_here

# ----------------------------------------------------------
# Meilisearch 配置
# ----------------------------------------------------------
MEILISEARCH_MASTER_KEY=your_meili_master_key_here

# ----------------------------------------------------------
# Embedding API 配置
# ----------------------------------------------------------
EMBEDDING_API_KEY=your_embedding_api_key_here

# ----------------------------------------------------------
# Qwen API 配置
# ----------------------------------------------------------
QWEN_API_KEY=your_qwen_api_key_here
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# ----------------------------------------------------------
# JWT & 加密配置
# ----------------------------------------------------------
JWT_CERTIFICATE_PASSWORD=your_jwt_cert_password_here
STRING_ENCRYPTION_PASSPHRASE=your_encryption_passphrase_here

# ----------------------------------------------------------
# Docker 镜像配置
# -----------------------------------------------------------
# 使用阿里云镜像仓库（国内加速）
# REGISTRY=registry.cn-zhangjiakou.aliyuncs.com/myelixir
# 使用 Docker Hub
REGISTRY=mycompany
IMAGE_TAG=latest
